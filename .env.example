# Core runtime
SYMBOL=BTC/USDT
TIMEFRAME=1h
EXCHANGE=kraken
DATA_LIMIT=500
SEND_HEARTBEAT=true

# Discord webhooks
DISCORD_WEBHOOK_URL=
DISCORD_HEARTBEAT_WEBHOOK_URL=
DISCORD_TEST_WEBHOOK_URL=
TEST_MODE=false

# Strategy filters
VOLUME_RATIO_MIN=0.54
VOLUME_SPIKE_MIN=1.10
CHOP_NO_TRADE_MAX=60
ATR_PCT_MIN=0.0046
ATR_EXTREME_MULT=2.45
RSI_MIN=39
RSI_MAX=61

# Risk management
ATR_STOP_MULT=2.54
TP1_MULT=1.81
TP2_MULT=2.99
COOLDOWN_BARS=7
COOLDOWN_BARS_SL=32
TIME_STOP_BARS=38

# Backtest configuration
INITIAL_CAPITAL=100
FEE_RATE=0.0004
SLIPPAGE_BPS=0.0002
HIST_EXCHANGE=binance
START_DATE=2023-01-01
WARMUP_BARS=220
LONG_ONLY=false

# Optional fallback stop/take-profit logic in backtest
SL_PCT=0.01
TP_PCT=0.02
USE_ATR_STOPS=true
ATR_MULT_SL=1.5
ATR_MULT_TP=2.5

# Plot settings (test_backtest.py)
PLOT_TRADES=true
PLOT_PATH=backtest_plot.png
PLOT_DAYS=60
PLOT_MAX_BARS=
PLOT_LABEL_TRADES=false
PLOT_DEBUG=false
PLOT_START_DATE=

# Optimization settings
GRID_TRIALS=20

# Optional debug script variables
CHOP_TREND_MAX=60
EMA_GAP_MIN=0.002
RSI_PULLBACK_LONG_MIN=35
RSI_PULLBACK_LONG_MAX=60
